    private void loadData() {
        this.list.clear();

        try {
            String query = "SELECT * FROM students ORDER BY id";
            ResultSet rs = this.conn.createStatement().executeQuery(query);

            while(rs.next()) {
                this.list.add(new Student(rs.getInt("id"), rs.getString("name"), rs.getString("course"), rs.getString("year_level")));
            }

            this.table.setItems(this.list);
        } catch (SQLException e) {
            e.printStackTrace();
            this.showAlert(AlertType.ERROR, "Load Error", "Failed to load student records.");
        }

    }

    @FXML
    private void addStudent() {
        if (this.validateInputs()) {
            try {
                String query = "INSERT INTO students(name, course, year_level) VALUES (?, ?, ?)";
                PreparedStatement pst = this.conn.prepareStatement(query);
                pst.setString(1, this.txtName.getText().trim());
                pst.setString(2, this.txtCourse.getText().trim());
                pst.setString(3, ((YearLevel)this.cbYear.getValue()).toString());
                pst.executeUpdate();
                this.loadData();
                this.clearFields();
                this.showAlert(AlertType.INFORMATION, "Success", "Student added successfully.");
            } catch (SQLException e) {
                e.printStackTrace();
                this.showAlert(AlertType.ERROR, "Insert Error", "Failed to add student: " + e.getMessage());
            }

        }
    }

    @FXML
    private void updateStudent() {
        if (this.selectedId == -1) {
            this.showAlert(AlertType.WARNING, "No Selection", "Please select a student to update.");
        } else if (this.validateInputs()) {
            try {
                String query = "UPDATE students SET name=?, course=?, year_level=? WHERE id=?";
                PreparedStatement pst = this.conn.prepareStatement(query);
                pst.setString(1, this.txtName.getText().trim());
                pst.setString(2, this.txtCourse.getText().trim());
                pst.setString(3, ((YearLevel)this.cbYear.getValue()).toString());
                pst.setInt(4, this.selectedId);
                pst.executeUpdate();
                this.loadData();
                this.clearFields();
                this.showAlert(AlertType.INFORMATION, "Success", "Student updated successfully.");
            } catch (SQLException e) {
                e.printStackTrace();
                this.showAlert(AlertType.ERROR, "Update Error", "Failed to update student: " + e.getMessage());
            }

        }
    }

    @FXML
    private void deleteStudent() {
        if (this.selectedId == -1) {
            this.showAlert(AlertType.WARNING, "No Selection", "Please select a student to delete.");
        } else {
            Alert confirm = new Alert(AlertType.CONFIRMATION);
            confirm.setTitle("Confirm Delete");
            confirm.setHeaderText((String)null);
            confirm.setContentText("Are you sure you want to delete this student?");
            confirm.showAndWait().ifPresent((response) -> {
                if (response == ButtonType.OK) {
                    try {
                        String query = "DELETE FROM students WHERE id=?";
                        PreparedStatement pst = this.conn.prepareStatement(query);
                        pst.setInt(1, this.selectedId);
                        pst.executeUpdate();
                        this.loadData();
                        this.clearFields();
                        this.showAlert(AlertType.INFORMATION, "Success", "Student deleted successfully.");
                    } catch (SQLException e) {
                        e.printStackTrace();
                        this.showAlert(AlertType.ERROR, "Delete Error", "Failed to delete student: " + e.getMessage());
                    }
                }

            });
        }
    }

