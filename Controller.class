    @FXML
    public void initialize() {
        this.conn = DBConnection.connect();
        if (this.conn == null) {
            this.showAlert(AlertType.ERROR, "Database Error", "Could not connect to the database.\nCheck your .env credentials.");
        } else {
            this.cbYear.getItems().setAll(YearLevel.values());
            this.colId.setCellValueFactory((data) -> ((Student)data.getValue()).idProperty().asObject());
            this.colName.setCellValueFactory((data) -> ((Student)data.getValue()).nameProperty());
            this.colCourse.setCellValueFactory((data) -> ((Student)data.getValue()).courseProperty());
            this.colYear.setCellValueFactory((data) -> ((Student)data.getValue()).yearLevelProperty());
            this.loadData();
