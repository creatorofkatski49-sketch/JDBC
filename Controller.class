        this.txtName.clear();
        this.txtCourse.clear();
        this.cbYear.setValue((Object)null);
        this.selectedId = -1;
        this.table.getSelectionModel().clearSelection();
    }

    private boolean validateInputs() {
        if (this.txtName.getText().trim().isEmpty()) {
            this.showAlert(AlertType.WARNING, "Validation Error", "Name cannot be empty.");
            this.txtName.requestFocus();
            return false;
        } else if (this.txtCourse.getText().trim().isEmpty()) {
            this.showAlert(AlertType.WARNING, "Validation Error", "Course cannot be empty.");
            this.txtCourse.requestFocus();
            return false;
        } else if (this.cbYear.getValue() == null) {
            this.showAlert(AlertType.WARNING, "Validation Error", "Please select a year level.");
            this.cbYear.requestFocus();
            return false;
        } else {
            return true;
        }
    }

